{
  "name": "qr-studio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "QR Studio - a premium Liquid Glass QR code generator with a sequence-wise wizard, 12 data types, batch generation, history, and multi-format export.",
  "author": "Karan Veer Thakur",
  "keywords": [
    "qr-code",
    "generator",
    "react",
    "liquid-glass",
    "vite",
    "typescript"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:netlify": "npm run build",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
